# Application
APP_NAME=http-metadata-inventory
APP_ENV=development
LOG_LEVEL=INFO
# "plain" (default) for human-readable logs, "json" for structured logs.
LOG_FORMAT=plain

# API
API_HOST=0.0.0.0
API_PORT=8000

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=metadata_inventory
MONGO_COLLECTION=metadata

# HTTP fetcher
FETCH_TIMEOUT_SECONDS=10
FETCH_MAX_REDIRECTS=5
FETCH_USER_AGENT=http-metadata-inventory/0.1
# 0 disables per-domain throttling; set to >= 1 to cap concurrent requests per host.
FETCH_PER_DOMAIN_CONCURRENCY=0
# Hard cap on the response body we ingest, in bytes.  Default: 5 MiB.
FETCH_MAX_BODY_BYTES=5242880
# SSRF guard.  When true, any URL whose host resolves to a private, loopback,
# link-local, multicast, or unspecified address is refused (IANA "reserved" is
# intentionally not blocked — see README / app.services.url_security).
FETCH_BLOCK_PRIVATE_NETWORKS=true
# Comma-separated list of hostnames that should be rejected outright.
FETCH_BLOCKED_HOSTS=

# Background worker
WORKER_QUEUE_MAXSIZE=1000
WORKER_CONCURRENCY=2
# On startup, re-enqueue records that were stuck in `pending` from a previous run.
WORKER_RESUME_PENDING_ON_STARTUP=true
